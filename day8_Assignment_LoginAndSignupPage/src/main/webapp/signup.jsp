<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>signup page</title>
</head>
<body>
<u><h1>Sign Up Page</h1></u>

<form action="signup">
	<label>UserName:  </label>
	<input type="text", name = "uname" placeholder="enter the name"><br><br>
	<label>Password: </label>
	<input type="password", name="pwd" placeholder="enter the password"><br><br>
	<label>Email: </label>
	<input type="email", name = "email" placeholder="enter the email"><br><br>
	<label>Mobile No: </label>
	<input type="number" name= "mno" placeholder="enter the Phone Number"><br><br>
	<button>Submit</button>
	</form>
	<br>

</body>
</html>